<h1>Add a New Player</h1>
<% if (typeof errors !== 'undefined' && errors.length > 0) { %>
  <ul style="color:red;">
    <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
  </ul>
<% } %>
<form action="/players" method="POST">
  <label>First Name: <input type="text" name="firstName" required></label><br>
  <label>Last Name: <input type="text" name="lastName" required></label><br>
  <label>Position: <input type="text" name="position"></label><br>
  <label>Nationality: <input type="text" name="nationality"></label><br>
  
  <label>Club:
    <select name="clubId" required>
      <option value="">-- Please choose a club --</option>
      <% clubs.forEach(club => { %>
        <option value="<%= club.id %>"><%= club.name %></option>
      <% }) %>
    </select>
  </label><br>
  
  <button type="submit">Register Player</button>
</form>