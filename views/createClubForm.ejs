<h1>Create a New Club</h1>
<% if (typeof errors !== 'undefined' && errors.length > 0) { %>
  <ul style="color:red;">
    <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
  </ul>
<% } %>
<form action="/clubs" method="POST">
  <label>Club Name: <input type="text" name="name" required></label><br>
  <label>Stadium: <input type="text" name="stadium" required></label><br>
  <label>Country: <input type="text" name="country" required></label><br>
  <button type="submit">Save Club</button>
</form>
<a href="/clubs">Cancel</a>