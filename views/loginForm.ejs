<!-- loginForm.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SquadVault - Login</title>
    <style>
        .error-list {color: red; margin-bottom: 10px;}
        .form-group {margin-bottom: 15px;}
        input {display: block; width: 100%; padding: 10px; margin-bottom: 15px;}
    </style>
</head>
<body>
    <h1>Login</h1>

    <% if (locals.errors && errors.length > 0) { %>
        <ul class="error-list">
            <% errors.forEach(error => { %>
                <li><%= error.msg %></li>
            <% }) %>
        </ul>
    <% } %>

    <form action="/auth/login" method="POST">
        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" name="email" id="email" required value="<%= locals.formData ? formData.email : '' %>">
        </div>
        <div class="form-group">
            <label for="password">Password</label>
            <input type="password" name="password" id="password" required minlength="8">
        </div>
        <button type="submit">Login</button>
    </form>

</body>
</html>