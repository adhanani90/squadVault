{
  "name": "squadvault",
  "version": "1.0.0",
  "description": "A comprehensive football club and player management vault built with Express and PostgreSQL.",
  "main": "app.js",
  "scripts": {
    "start": "node db/populateDB.js && node app.js",
    "dev:api": "nodemon app.js",
    "dev:client": "cd client && npm run dev",
    "test": "jest --globalSetup=./tests/setup.js --runInBand --detectOpenHandles",
    "test:watch": "jest --watchAll --globalSetup=./tests/setup.js --runInBand",
    "build": "cd client && npm install && vite build --outDir ../dist",
    "test:coverage": "jest --globalSetup=./tests/setup.js --coverage --runInBand --detectOpenHandles"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YOUR_USERNAME/squadvault.git"
  },
  "keywords": [
    "express",
    "postgresql",
    "squad-management",
    "football",
    "auth",
    "jwt"
  ],
  "author": "Your Name",
  "license": "ISC",
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "method-override": "^3.0.0",
    "pg": "^8.20.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.claude/"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/.claude/"
    ]
  }
}
